# ==================================================
# Application Configuration
# ==================================================
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:3000

# ==================================================
# Database Configuration
# ==================================================
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_db_password
DB_NAME=incollabe_db
DB_DIALECT=postgres

# ==================================================
# JWT Authentication
# ==================================================
# JWT Secret - MUST be shared between this app and external app for brand authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=7d
JWT_REFRESH_SECRET=your-refresh-token-secret
JWT_REFRESH_EXPIRATION=30d

# ==================================================
# External API Configuration (NEW)
# ==================================================
# Comma-separated API keys for external platforms
# Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
EXTERNAL_API_KEYS=external-app-key-1,external-app-key-2,external-app-key-3

# ==================================================
# Redis Configuration
# ==================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==================================================
# AWS S3 Configuration
# ==================================================
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=your-s3-bucket-name
AWS_CLOUDFRONT_DOMAIN=your-cloudfront-domain.cloudfront.net
AWS_CLOUDFRONT_KEY_PAIR_ID=your-cloudfront-keypair-id
AWS_CLOUDFRONT_PRIVATE_KEY_PATH=/path/to/cloudfront-private-key.pem

# ==================================================
# Firebase Configuration
# ==================================================
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com

# ==================================================
# Payment Gateway (Razorpay)
# ==================================================
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ==================================================
# Email Configuration
# ==================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-email-app-password
EMAIL_FROM=noreply@incollabe.com

# ==================================================
# Social Media Integration
# ==================================================
INSTAGRAM_APP_ID=your_instagram_app_id
INSTAGRAM_APP_SECRET=your_instagram_app_secret
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# ==================================================
# AI Services
# ==================================================
OPENAI_API_KEY=your_openai_api_key
# NOTE: Variable name is GEMINI_API_KEY (not GOOGLE_GEMINI_API_KEY)
# Used by GeminiAIService + ShoppingAgentService
GEMINI_API_KEY=your_google_gemini_api_key

# ==================================================
# Meta Webhook — Instagram DM Bot
# ==================================================
# Token you set in Meta for Developers → Webhooks → Verify Token field
IG_VERIFY_TOKEN=your_meta_webhook_verify_token
# App Secret from Meta for Developers → App Settings → Basic (used to verify X-Hub-Signature-256)
# NOTE: Use IG_WEBHOOK_APP_SECRET (not IG_APP_SECRET) to avoid conflict with OAuth app secret
IG_WEBHOOK_APP_SECRET=your_meta_app_secret
# Page Access Token from Meta Graph API Explorer (long-lived token for sending DMs)
IG_PAGE_ACCESS_TOKEN=your_instagram_page_access_token
# Graph API version (default: v21.0)
IG_GRAPH_VERSION=v21.0
# Callback URL to register in Meta for Developers → Webhooks:
#   https://your-domain.com/api/webhooks/meta

# ==================================================
# Shopping Feature (Reel Scanner + Catalog Search + Shopping Agent)
# ==================================================
# Separate Gemini API key for the shopping agent (function calling + thinking models)
SHOPPING_GEMINI_API_KEY=your_shopping_gemini_api_key
# Optional — catalog cache duration in ms (default: 3600000 = 1 hour)
CATALOG_TTL_MS=3600000
# Required for Razorpay payment links (where user is redirected after payment)
PAYMENT_CALLBACK_URL=https://incollab.buymybills.in/payment/callback

# ==================================================
# Monitoring & Logging
# ==================================================
LOG_LEVEL=info
SENTRY_DSN=your_sentry_dsn

# ==================================================
# CORS Configuration
# ==================================================
CORS_ORIGIN=http://localhost:3000,https://your-frontend-domain.com

# ==================================================
# Rate Limiting
# ==================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
