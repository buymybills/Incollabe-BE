# ============================================================
# Configuration for External Backend Integration
# ============================================================
# Copy these values to your .env file

# API Base URL - Where to send requests
# Production
INCOLLABE_API_URL=https://api.incollabe.com/api

# Development (for testing)
# INCOLLABE_API_URL=http://localhost:3000/api

# API Key - Authentication credential
INCOLLABE_API_KEY=external_backend_live_sk_6acd01e532c9ec6268d480d650a65e88084ba88ff5399708054a710125f59e4b

# Your Application Identifier (used in x-app-id header)
INCOLLABE_APP_ID=your-app-name

