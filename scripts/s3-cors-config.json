[
    {
        "AllowedHeaders": [
            "*"
        ],
        "AllowedMethods": [
            "GET",
            "PUT",
            "POST",
            "DELETE",
            "HEAD"
        ],
        "AllowedOrigins": [
            "https://app.incollabe.com",
            "https://staging.incollabe.com",
            "http://localhost:3000",
            "http://localhost:3001"
        ],
        "ExposeHeaders": [
